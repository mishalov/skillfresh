{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "Payment"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "payment_type": {
      "type": "string",
      "required": true
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "Completed",
        "Error"
      ]
    },
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order",
      "inversedBy": "payments"
    },
    "additional_info": {
      "type": "text"
    }
  }
}
