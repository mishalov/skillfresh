{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "integer",
      "min": 15,
      "default": 60
    },
    "description": {
      "type": "text"
    },
    "additional_info": {
      "type": "richtext"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "lessons"
    },
    "scheduled": {
      "type": "datetime"
    },
    "feedbacks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::feedback.feedback",
      "mappedBy": "lessons"
    }
  }
}
