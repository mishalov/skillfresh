{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "default": 0
    },
    "date_start": {
      "type": "datetime"
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "Future",
        "In progress",
        "Completed"
      ],
      "default": "Future"
    },
    "teachers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "courses"
    },
    "notion_link": {
      "type": "string"
    },
    "notes": {
      "type": "richtext"
    },
    "discount": {
      "type": "integer",
      "min": 0,
      "max": 100
    },
    "lessons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lesson.lesson",
      "mappedBy": "course"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "course"
    },
    "leads": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::lead.lead",
      "mappedBy": "courses"
    },
    "feedbacks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::feedback.feedback",
      "mappedBy": "courses"
    }
  }
}
